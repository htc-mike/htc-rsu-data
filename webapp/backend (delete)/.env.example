# Supabase Configuration
# Copy this file to .env and fill in your Supabase credentials

# Get these from your Supabase project dashboard: https://supabase.com/dashboard/project/anxkcikdwqtcuetootti/settings/database
SUPABASE_URL=https://anxkcikdwqtcuetootti.supabase.co
SUPABASE_DB_HOST=db.anxkcikdwqtcuetootti.supabase.co
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=htc_app_user
SUPABASE_DB_PASSWORD=your_secure_password_here

# Alternative: Use Session Pooler (better for IPv4 networks)
# SUPABASE_DB_HOST=aws-0-us-east-1.pooler.supabase.com:6543

# For local development (comment out when using Supabase)
# LOCAL_DB_HOST=localhost
# LOCAL_DB_PORT=5432
# LOCAL_DB_NAME=htc
# LOCAL_DB_USER=postgres
# LOCAL_DB_PASSWORD=your_local_password
